# Copy this file to .env and fill in real values.
# .env is gitignored — secrets stay out of version control.

# Supabase project ID (from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Supabase anon/public key (from same page — RLS-protected, safe in client)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Korapay public key (Korapay dashboard → Settings → API Keys)
VITE_KORAPAY_PUBLIC_KEY=your_korapay_public_key_here

# Admin email — used as a bootstrap fallback for admin access
VITE_ADMIN_EMAIL=admin@admin.com
